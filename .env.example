# --- eBay Browse API (required) ---
# Get free credentials at https://developer.ebay.com/
# After signing in, create a "Production" keyset; App ID = client_id, Cert ID = client_secret.
EBAY_APP_ID=
EBAY_CERT_ID=

# --- eBay Trading API (optional; enables per-bid timestamps) ---
# Dev ID is on the same Production keyset page. User Token must be an
# Auth'n'Auth token for your own seller account.
# When both are set, the snapshot includes a bid timestamp for each auction
# and a `lastBid` summary across all auctions.
EBAY_DEV_ID=
EBAY_USER_TOKEN=
EBAY_USER_TOKEN_FILE=.cache/ebay-auth-token.json

# Default eBay seller whose live auctions are tracked.
EBAY_SELLER_ID=ryan_5050

# eBay marketplace; see https://developer.ebay.com/api-docs/static/rest-request-components.html#marketpl
EBAY_MARKETPLACE_ID=EBAY_US

# --- Stock price (Finnhub primary, Yahoo fallback) ---
# Finnhub: https://finnhub.io/register (free; 60 calls/min). Optional but recommended.
FINNHUB_API_KEY=

# Stock ticker for the "stock half" of the half-cash-half-stock math.
STOCK_SYMBOL=EBAY

# --- Server ---
PORT=3000
LOG_LEVEL=info

# --- Postgres (optional but recommended) ---
# When set, enables: cross-instance request dedup (cache_entries),
# bid history persistence (listings, bids), and OHLC candle storage
# with backfill (ohlc_data). Migrations run automatically on startup.
# Render provides this automatically when you attach a Postgres add-on.
DATABASE_URL=

# Set to "true" to expose /api/debug/ohlc-stats for verifying historical
# OHLC backfill on dev environments. Leave unset/false in production.
ENABLE_DEBUG_ENDPOINTS=false

# --- Admin dashboard (optional) ---
# Label for this deployment, used to tag request_stats rows so dev/prod
# traffic can be distinguished in the admin dashboard. Falls back to
# NODE_ENV if unset. Set to "dev", "prod", or any short label per service.
APP_ENVIRONMENT=

# Token required to access /admin and /api/admin/stats. Must be at least
# 8 characters. If unset, the admin dashboard returns 503.
ADMIN_TOKEN=
