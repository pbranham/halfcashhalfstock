{
  "name": "halfcashhalfstock",
  "version": "0.1.0",
  "private": true,
  "description": "Live monitor for Ryan Cohen's eBay auctions, expressed as half cash + half EBAY stock.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run"
  },
  "dependencies": {
    "compression": "1.7.5",
    "dotenv": "16.6.1",
    "express": "4.21.2",
    "express-rate-limit": "7.4.1",
    "fast-xml-parser": "5.7.3",
    "helmet": "8.0.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "@types/compression": "1.7.5",
    "@types/express": "4.17.21",
    "@types/node": "22.10.2",
    "eslint": "9.17.0",
    "eslint-config-prettier": "9.1.0",
    "globals": "15.14.0",
    "prettier": "3.4.2",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "typescript-eslint": "8.18.2",
    "vitest": "2.1.8"
  }
}
